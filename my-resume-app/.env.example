# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# React frontend — all REACT_APP_ vars are bundled into the client build
REACT_APP_WEATHER_API_KEY=your_openweathermap_api_key
REACT_APP_TMDB_API_KEY=your_tmdb_api_key
REACT_APP_TMDB_ACCESS_TOKEN=your_tmdb_bearer_token
REACT_APP_RECAPTCHA_SITE_KEY=your_google_recaptcha_v2_site_key

# Server-side only (not exposed to browser)
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=465
SMTP_USER=you@yourdomain.com
SMTP_PASS=your_smtp_password
CONTACT_RECIPIENT=you@yourdomain.com
